# ⚠️ IMPORTANT: Ne jamais commiter ce fichier dans Git
# Gardez vos clés API et credentials secrets
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs

# Google Gemini API Key
GEMINI_API_KEY=votre_cle_gemini_ici

# MongoDB Atlas - ⚠️ Utiliser des variables d'environnement en production
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/GestionEau?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=GestionEau

# Frontend API URL (Vite)
# ⚠️ NOTE: En mode développement (npm run dev), l'URL est automatiquement détectée
# Le frontend utilisera la même adresse que celle utilisée pour y accéder
# Exemple: 
#   - http://localhost:3000/ → API: http://localhost:5000/api
#   - http://192.168.1.39:3000/ → API: http://192.168.1.39:5000/api
# Cette variable est surtout utile en production (après build)
VITE_API_URL=http://localhost:5000/api
